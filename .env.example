# -------------------------------------------------------
# 202BBQ Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it's in .gitignore.
# -------------------------------------------------------

# EmailJS — sign up free at https://emailjs.com
# 1. Add a service (connect your Gmail)
# 2. Create two templates (Orders + Reviews)
# 3. Copy your Public Key from Account > API Keys
VITE_EMAILJS_PUBLIC_KEY=REPLACE_ME
VITE_EMAILJS_SERVICE_ID=REPLACE_ME
VITE_EMAILJS_ORDERS_TEMPLATE=REPLACE_ME
VITE_EMAILJS_REVIEWS_TEMPLATE=REPLACE_ME
