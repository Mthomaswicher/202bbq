# -------------------------------------------------------
# 202BBQ Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it's in .gitignore.
# -------------------------------------------------------

# Formspree endpoints — sign up free at https://formspree.io
# Create two forms (Orders + Reviews) and paste the IDs below.
# Your endpoint will look like: https://formspree.io/f/abcdefgh
VITE_FORMSPREE_ORDERS=https://formspree.io/f/REPLACE_WITH_YOUR_ORDERS_FORM_ID
VITE_FORMSPREE_REVIEWS=https://formspree.io/f/REPLACE_WITH_YOUR_REVIEWS_FORM_ID
