# -------------------------------------------------------
# 202BBQ Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local. It's in .gitignore.
# -------------------------------------------------------

# Formspree: sign up free at https://formspree.io
# Create forms and paste the full submit URLs below.

# Local catering orders (Order Now section)
VITE_FORMSPREE_ORDERS=https://formspree.io/f/REPLACE_ME

# Nationwide shipping orders (Oxtail Softballs cart checkout)
# You can use the same form as ORDERS, or create a separate one for shipping.
VITE_FORMSPREE_SHIPPING=https://formspree.io/f/REPLACE_ME

# Customer reviews
VITE_FORMSPREE_REVIEWS=https://formspree.io/f/REPLACE_ME

# Catering / custom order inquiries (Contact section)
VITE_FORMSPREE_CONTACT=https://formspree.io/f/REPLACE_ME

# Stripe Payment Link: fixed $20 order deposit (local catering)
# 1. Go to https://dashboard.stripe.com/payment-links
# 2. Click "New" → "Products or subscriptions"
# 3. Product name: "202BBQ Order Deposit", Price: $20 USD, one-time
# 4. Under "After payment" → "Don't show confirmation page"
#    (optional: set a redirect to https://202barbecue.com)
# 5. Under "Advanced options" → enable "Collect customer's phone number"
# 6. Create the link and copy the URL below
VITE_STRIPE_DEPOSIT_LINK=https://buy.stripe.com/REPLACE_ME
